# ──────────────────────────────────────────────────────────────────────────
# Fable Portfolio Starter — environment variables
# Copy to `.env.local` (gitignored) and set per brand. Vercel: set per project.
# Only NEXT_PUBLIC_* values are exposed to the browser. SECRETS MUST NOT use the
# NEXT_PUBLIC_ prefix and must NEVER be committed.
# ──────────────────────────────────────────────────────────────────────────

# Active brand. One of: elevate | apex | events | education
# Missing -> defaults to "elevate" (dev convenience). Invalid -> build throws.
NEXT_PUBLIC_BRAND=elevate

# Public site URL used for canonical links, sitemap, JSON-LD.
NEXT_PUBLIC_SITE_URL=https://example.com

# Forces the global demo banner + [Sample] labels on. INTERNAL DRAFT default: on.
NEXT_PUBLIC_DEMO_MODE=true

# Feature flag overrides (optional). Pattern: NEXT_PUBLIC_FLAG_<UPPER_SNAKE>=true|false
# NEXT_PUBLIC_FLAG_PRO_APPLY_FORM=true
# NEXT_PUBLIC_FLAG_WAITLIST_FORM=true

# Example secret placeholder (server-only; NOT exposed to browser). None required by the starter.
# BOOKING_BACKEND_API_KEY=
